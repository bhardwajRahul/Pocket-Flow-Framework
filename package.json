{
  "name": "pocketflow",
  "version": "0.1.0",
  "description": "A TypeScript framework for building LLM-powered workflows using nested directed graphs",
  "main": "dist/pocket.js",
  "types": "dist/pocket.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@types/lodash": "^4.17.16",
    "lodash": "^4.17.21",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Osly-AI/Pocket-Flow-Framework.git"
  },
  "keywords": [
    "llm",
    "ai",
    "workflow",
    "agent",
    "dag",
    "flow",
    "framework",
    "typescript",
    "directed-graph",
    "task-decomposition",
    "rag"
  ],
  "author": "Pocket Flow Framework Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}